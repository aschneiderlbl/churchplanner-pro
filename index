<script>
/* Simple SPA router */
const routes = {
  'home':              { tpl: 'tpl-home',        crumb: ['Home'] },
  'workflows':         { tpl: 'tpl-workflows',   crumb: ['Workflows'] },
  'wf-workorder':      { tpl: 'tpl-wf-workorder',crumb: ['Workflows', 'Submit work order'] },
  'wf-workorder-resume':{tpl: 'tpl-wf-workorder',crumb: ['Home', 'Sanctuary HVAC'] },
  'wf-expense':        { tpl: 'tpl-wf-expense',  crumb: ['Workflows', 'Unplanned expense'] },
  'wf-donors':         { tpl: 'tpl-wf-donors',   crumb: ['Workflows', 'Re-engage lapsed donors'] },
  'vault':             { tpl: 'tpl-vault',       crumb: ['Vault'] },
  'review':            { tpl: 'tpl-review',      crumb: ['Review tables'] },
  'memory':            { tpl: 'tpl-memory',      crumb: ['Memory'] }
};
function go(route) {
  const r = routes[route] || routes.home;
  const tpl = document.getElementById(r.tpl);
  const view = document.getElementById('view');
  view.innerHTML = '';
  view.appendChild(tpl.content.cloneNode(true));
  // breadcrumb
  const crumb = document.getElementById('crumb');
  crumb.innerHTML = r.crumb.map((c, i) => i === r.crumb.length - 1 ? `<strong>${c}</strong>` : `${c} <span>/</span>`).join(' ');
  // active nav
  document.querySelectorAll('.nav-item[data-route]').forEach(n => n.classList.toggle('active', n.dataset.route === route || (route.startsWith('wf-') && n.dataset.route === 'workflows')));
  window.scrollTo({top: 0, behavior: 'instant'});
}
function runAsk() {
  const v = (document.getElementById('ask-input').value || '').toLowerCase();
  if (v.includes('donor') || v.includes('lapsed') || v.includes('giving')) return go('wf-donors');
  if (v.includes('expense') || v.includes('budget') || v.includes('forecast')) return go('wf-expense');
  if (v.includes('work') || v.includes('hvac') || v.includes('repair') || v.includes('fix')) return go('wf-workorder');
  go('wf-workorder');
}
/* init */
go('home');
</script>
