<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>ChurchPlanner Pro — AI operating system for churches</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
/* ====== Design tokens (from design-guidelines.pdf) ====== */
:root {
  --primary: #2563EB;
  --primary-hover: #1D4ED8;
  --primary-light: #DBEAFE;
  --cta: #22C55E;
  --cta-hover: #16A34A;
  --cta-light: #DCFCE7;
  --bg: #F5F7FA;
  --surface: #FFFFFF;
  --border: #E5E7EB;
  --text: #111827;
  --text-secondary: #6B7280;
  --text-disabled: #9CA3AF;
  --warning: #F59E0B;
  --error: #EF4444;

  --xs: 4px; --sm: 8px; --md: 16px; --lg: 24px; --xl: 32px; --xxl: 48px;

  --r-sm: 6px; --r-md: 8px; --r-lg: 12px; --r-pill: 999px;
  --shadow-sm: 0 1px 2px rgba(17, 24, 39, .04);
  --shadow-md: 0 4px 12px rgba(17, 24, 39, .06);
}

* { box-sizing: border-box; }
html, body { height: 100%; }
body {
  margin: 0;
  font-family: 'Inter', 'Roboto', -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 14px; line-height: 1.5;
  color: var(--text);
  background: var(--bg);
  -webkit-font-smoothing: antialiased;
}

/* ====== Typography scale ====== */
h1 { font-size: 32px; font-weight: 600; line-height: 1.25; margin: 0; letter-spacing: -0.02em; }
h2 { font-size: 24px; font-weight: 600; line-height: 1.3;  margin: 0; letter-spacing: -0.01em; }
h3 { font-size: 20px; font-weight: 600; line-height: 1.35; margin: 0; }
.body-lg { font-size: 16px; font-weight: 400; }
.body    { font-size: 14px; font-weight: 400; }
.caption { font-size: 12px; font-weight: 400; color: var(--text-secondary); }
.muted   { color: var(--text-secondary); }
.mono    { font-variant-numeric: tabular-nums; }

/* ====== Buttons ====== */
.btn {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 8px 16px; min-height: 36px;
  font-family: inherit; font-size: 14px; font-weight: 500;
  border-radius: var(--r-md); cursor: pointer; border: 1px solid transparent;
  transition: background-color 150ms ease-out, color 150ms ease-out, border-color 150ms ease-out, opacity 150ms ease-out;
  white-space: nowrap;
}
.btn:focus-visible { outline: 2px solid var(--primary); outline-offset: 2px; }
.btn-primary   { background: var(--cta); color: #fff; }
.btn-primary:hover { background: var(--cta-hover); }
.btn-secondary { background: var(--surface); color: var(--primary); border-color: var(--primary); }
.btn-secondary:hover { background: var(--primary-light); }
.btn-ghost { background: transparent; color: var(--text); }
.btn-ghost:hover { background: var(--bg); }
.btn-text  { background: transparent; color: var(--primary); padding: 6px 8px; min-height: 32px; }
.btn-text:hover { color: var(--primary-hover); text-decoration: underline; }
.btn-sm { padding: 6px 12px; min-height: 30px; font-size: 13px; }
.btn[disabled] { opacity: .4; cursor: not-allowed; }

/* ====== Inputs ====== */
.input, .textarea, .select {
  width: 100%; padding: 10px 14px;
  font: inherit; color: var(--text);
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--r-md);
  transition: border-color 150ms ease-out, box-shadow 150ms ease-out;
}
.textarea { min-height: 80px; resize: vertical; }
.input:focus, .textarea:focus, .select:focus {
  outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px rgba(37,99,235,.15);
}
label.field { display: block; margin-bottom: 8px; font-size: 13px; font-weight: 500; color: var(--text); }

/* ====== Cards ====== */
.card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--r-lg);
  padding: 24px;
}
.card.pad-md { padding: 16px; }
.card.hover { transition: box-shadow 150ms, transform 150ms, border-color 150ms; cursor: pointer; }
.card.hover:hover { box-shadow: var(--shadow-md); border-color: #CBD5E1; transform: translateY(-1px); }

/* ====== Chips / tags ====== */
.chip {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 4px 10px; font-size: 12px; font-weight: 500;
  border-radius: var(--r-pill);
  background: var(--bg); color: var(--text-secondary);
  border: 1px solid var(--border);
}
.chip.blue  { background: var(--primary-light); color: var(--primary); border-color: transparent; }
.chip.green { background: var(--cta-light); color: var(--cta-hover); border-color: transparent; }
.chip.amber { background: #FEF3C7; color: #B45309; border-color: transparent; }
.chip.red   { background: #FEE2E2; color: #B91C1C; border-color: transparent; }
.chip.dot::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: currentColor; }

/* ====== Layout shell ====== */
.app { display: grid; grid-template-columns: 248px 1fr; min-height: 100vh; }

.sidebar {
  background: var(--surface);
  border-right: 1px solid var(--border);
  padding: 16px 12px;
  display: flex; flex-direction: column; gap: 4px;
  position: sticky; top: 0; height: 100vh;
}
.brand {
  display: flex; align-items: center; gap: 10px;
  padding: 8px 10px 16px;
}
.brand-mark {
  width: 32px; height: 32px; border-radius: 8px;
  background: linear-gradient(135deg, #111827, #1F2937);
  color: #fff; display: grid; place-items: center;
  font-weight: 700; font-size: 15px; letter-spacing: -.02em;
}
.brand-name { font-weight: 600; font-size: 15px; }
.brand-sub  { font-size: 11px; color: var(--text-secondary); margin-top: 1px; }

.new-chat {
  display: flex; align-items: center; gap: 8px;
  padding: 10px 12px; margin: 4px 4px 12px;
  border: 1px solid var(--border); border-radius: var(--r-md);
  font-weight: 500; font-size: 13px; cursor: pointer; background: var(--surface);
  transition: background 150ms;
}
.new-chat:hover { background: var(--bg); }

.nav-section-label {
  padding: 10px 12px 6px; font-size: 11px; font-weight: 600;
  color: var(--text-secondary); letter-spacing: 0.04em; text-transform: uppercase;
}
.nav-item {
  display: flex; align-items: center; gap: 10px;
  padding: 8px 12px; margin: 0 4px;
  border-radius: var(--r-md); cursor: pointer;
  color: var(--text); font-size: 13.5px; font-weight: 500;
  transition: background 150ms, color 150ms;
}
.nav-item:hover { background: var(--bg); }
.nav-item.active { background: var(--primary-light); color: var(--primary); }
.nav-item .icon { width: 18px; height: 18px; stroke: currentColor; flex: none; }
.nav-item .count { margin-left: auto; font-size: 11px; color: var(--text-secondary); }
.nav-item.active .count { color: var(--primary); }

.sidebar-footer {
  margin-top: auto; padding: 12px 8px 4px; border-top: 1px solid var(--border);
  display: flex; align-items: center; gap: 10px;
}
.avatar { width: 32px; height: 32px; border-radius: 50%; background: #334155; color: #fff; display: grid; place-items: center; font-size: 12px; font-weight: 600; flex: none; }
.sidebar-footer .name { font-size: 13px; font-weight: 500; }
.sidebar-footer .org { font-size: 11px; color: var(--text-secondary); }

/* ====== Main content ====== */
.main { min-width: 0; display: flex; flex-direction: column; }
.topbar {
  display: flex; align-items: center; gap: 16px;
  padding: 12px 32px;
  background: var(--surface); border-bottom: 1px solid var(--border);
  position: sticky; top: 0; z-index: 5;
}
.crumb { font-size: 13px; color: var(--text-secondary); display: flex; align-items: center; gap: 6px; }
.crumb strong { color: var(--text); font-weight: 600; }
.topbar .spacer { flex: 1; }

.page { padding: 48px 32px; max-width: 1180px; margin: 0 auto; width: 100%; }
.page.narrow { max-width: 880px; }

/* ====== Home (Harvey-style) ====== */
.home-hero { text-align: left; margin-bottom: 40px; }
.home-hero h1 { margin-bottom: 8px; }
.home-hero .sub { color: var(--text-secondary); font-size: 16px; }

.ask-card {
  background: var(--surface);
  border: 1px solid var(--border); border-radius: var(--r-lg);
  padding: 20px; box-shadow: var(--shadow-sm);
}
.ask-card textarea {
  width: 100%; border: none; outline: none; resize: none;
  font: inherit; font-size: 16px; line-height: 1.5;
  min-height: 72px; background: transparent;
}
.ask-card textarea::placeholder { color: var(--text-disabled); }

.ask-toolbar {
  display: flex; align-items: center; gap: 8px;
  margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--border);
}
.ask-toolbar .left { display: flex; gap: 4px; flex-wrap: wrap; }
.ask-toolbar .right { margin-left: auto; display: flex; gap: 8px; align-items: center; }
.tool-btn {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 6px 10px; border-radius: var(--r-md);
  background: transparent; color: var(--text-secondary); font-size: 13px; cursor: pointer;
  border: 1px solid transparent;
}
.tool-btn:hover { background: var(--bg); color: var(--text); }

.source-chips { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 12px; }
.source-chip {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 5px 10px; font-size: 12px;
  border-radius: var(--r-pill);
  background: var(--bg); color: var(--text); border: 1px solid var(--border);
}

.suggestions-label {
  margin: 32px 0 12px;
  font-size: 12px; font-weight: 600; color: var(--text-secondary);
  letter-spacing: 0.04em; text-transform: uppercase;
}

.workflow-grid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;
}
.wf-card .badge {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 4px 8px; border-radius: var(--r-pill);
  background: var(--bg); color: var(--text-secondary);
  font-size: 11px; font-weight: 500;
}
.wf-card h3 { font-size: 16px; margin: 12px 0 6px; }
.wf-card p { color: var(--text-secondary); font-size: 13px; margin: 0; }
.wf-card .meta {
  margin-top: 16px; display: flex; justify-content: space-between; align-items: center;
  color: var(--text-secondary); font-size: 12px;
}
.wf-icon {
  width: 36px; height: 36px; border-radius: 8px;
  display: grid; place-items: center;
  color: var(--primary); background: var(--primary-light);
}
.wf-icon.green { color: var(--cta-hover); background: var(--cta-light); }
.wf-icon.amber { color: #B45309; background: #FEF3C7; }

.recent-list { display: grid; gap: 8px; }
.recent-row {
  display: grid; grid-template-columns: 24px 1fr auto auto; align-items: center; gap: 16px;
  padding: 12px 16px; border: 1px solid var(--border); border-radius: var(--r-md); background: var(--surface); cursor: pointer;
  transition: border-color 150ms, background 150ms;
}
.recent-row:hover { border-color: #CBD5E1; background: #FAFBFC; }
.recent-row .title { font-weight: 500; font-size: 14px; }
.recent-row .time  { color: var(--text-secondary); font-size: 12px; }

/* ====== Workflow run view ====== */
.run-layout { display: grid; grid-template-columns: 320px 1fr; gap: 32px; align-items: start; }
@media (max-width: 1100px) { .run-layout { grid-template-columns: 1fr; } }

.stepper { display: grid; gap: 6px; position: sticky; top: 80px; }
.step {
  display: grid; grid-template-columns: 28px 1fr; gap: 12px; align-items: start;
  padding: 12px; border-radius: var(--r-md); cursor: pointer;
  transition: background 150ms;
}
.step:hover { background: var(--surface); }
.step-dot {
  width: 24px; height: 24px; border-radius: 50%;
  display: grid; place-items: center;
  background: var(--surface); border: 1.5px solid var(--border);
  font-size: 11px; font-weight: 600; color: var(--text-secondary);
  margin-top: 2px;
}
.step.done .step-dot   { background: var(--cta); border-color: var(--cta); color: #fff; }
.step.active .step-dot { background: var(--primary); border-color: var(--primary); color: #fff; }
.step-title { font-size: 13.5px; font-weight: 500; color: var(--text); }
.step-sub   { font-size: 12px; color: var(--text-secondary); margin-top: 2px; }
.step.active .step-title { color: var(--primary); }
.step .line {
  grid-column: 1; width: 1.5px; background: var(--border); margin: 0 auto; height: 20px;
}
.step.done .line { background: var(--cta); }

.run-panel { display: grid; gap: 16px; }
.run-header { display: flex; align-items: center; gap: 12px; margin-bottom: 8px; }
.run-header h2 { flex: 1; }
.run-header .status { font-size: 12px; color: var(--text-secondary); }

.section-title { font-size: 12px; font-weight: 600; color: var(--text-secondary); letter-spacing: 0.04em; text-transform: uppercase; margin-bottom: 12px; }

.form-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
.form-grid .full { grid-column: 1 / -1; }

.actions-row { display: flex; gap: 8px; justify-content: flex-end; margin-top: 8px; }

/* ====== Document-like output panel ====== */
.doc-panel {
  background: var(--surface); border: 1px solid var(--border); border-radius: var(--r-lg);
  padding: 32px 40px;
}
.doc-panel h2 { margin-bottom: 8px; }
.doc-panel .doc-meta { color: var(--text-secondary); font-size: 13px; margin-bottom: 24px; }
.doc-panel p { margin: 0 0 12px; font-size: 15px; line-height: 1.65; }
.doc-panel em.citation {
  display: inline-block; background: var(--bg); color: var(--primary);
  padding: 0 6px; font-style: normal; font-size: 11px; font-weight: 500;
  border-radius: var(--r-pill); vertical-align: middle; margin: 0 2px;
}

/* ====== Tables ====== */
.table {
  width: 100%; border-collapse: separate; border-spacing: 0;
  background: var(--surface); border: 1px solid var(--border); border-radius: var(--r-lg); overflow: hidden;
}
.table th, .table td {
  text-align: left; padding: 12px 16px; font-size: 13.5px;
  border-bottom: 1px solid var(--border);
}
.table th { font-weight: 600; color: var(--text-secondary); font-size: 12px; letter-spacing: 0.02em; text-transform: uppercase; background: #FAFBFC; }
.table tr:last-child td { border-bottom: none; }
.table tr.row-hover:hover { background: #FAFBFC; cursor: pointer; }

/* ====== Vendor cards / quotes ====== */
.quote-card {
  display: grid; grid-template-columns: 1fr auto; gap: 8px; align-items: center;
  padding: 16px; border: 1px solid var(--border); border-radius: var(--r-md); background: var(--surface);
}
.quote-card .vendor { font-weight: 600; font-size: 14px; }
.quote-card .price  { font-size: 18px; font-weight: 600; font-variant-numeric: tabular-nums; }
.quote-card .detail { font-size: 12px; color: var(--text-secondary); margin-top: 2px; }
.quote-card.selected { border-color: var(--cta); background: var(--cta-light); }

/* ====== Charts (simple bars) ====== */
.bar-chart { display: grid; gap: 8px; }
.bar-row { display: grid; grid-template-columns: 110px 1fr 80px; align-items: center; gap: 12px; font-size: 13px; }
.bar-track { height: 10px; background: var(--bg); border-radius: var(--r-pill); overflow: hidden; }
.bar-fill { height: 100%; background: var(--primary); }
.bar-fill.green { background: var(--cta); }
.bar-fill.amber { background: var(--warning); }
.bar-fill.red   { background: var(--error); }
.bar-val { text-align: right; color: var(--text-secondary); font-variant-numeric: tabular-nums; }

/* Option tiles */
.option-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
.option-tile {
  display: grid; grid-template-columns: 20px 1fr; gap: 12px; align-items: start;
  padding: 16px; border: 1px solid var(--border); border-radius: var(--r-md); cursor: pointer;
  transition: all 150ms;
}
.option-tile:hover { border-color: #CBD5E1; }
.option-tile.selected { border-color: var(--primary); background: var(--primary-light); }
.option-radio { width: 18px; height: 18px; border-radius: 50%; border: 2px solid var(--border); margin-top: 2px; flex: none; }
.option-tile.selected .option-radio { border-color: var(--primary); background: radial-gradient(circle, var(--primary) 40%, var(--primary-light) 45%); }
.option-tile .t { font-weight: 500; font-size: 14px; }
.option-tile .d { color: var(--text-secondary); font-size: 12.5px; margin-top: 4px; }

/* Email draft */
.email-draft {
  background: var(--surface); border: 1px solid var(--border); border-radius: var(--r-lg); overflow: hidden;
}
.email-header { padding: 12px 16px; border-bottom: 1px solid var(--border); display: grid; gap: 4px; font-size: 13px; }
.email-header .row { display: grid; grid-template-columns: 60px 1fr; gap: 8px; }
.email-header .row span:first-child { color: var(--text-secondary); }
.email-body { padding: 24px; }
.email-body p { margin: 0 0 14px; font-size: 14.5px; line-height: 1.65; }

/* ====== Utility ====== */
.row { display: flex; align-items: center; gap: 8px; }
.gap-sm { gap: 8px; } .gap-md { gap: 16px; } .gap-lg { gap: 24px; }
.stack { display: grid; gap: 16px; }
.stack-sm { display: grid; gap: 8px; }
.stack-lg { display: grid; gap: 24px; }
.mt-sm { margin-top: 8px; } .mt-md { margin-top: 16px; } .mt-lg { margin-top: 24px; } .mt-xl { margin-top: 32px; }
.mb-sm { margin-bottom: 8px; } .mb-md { margin-bottom: 16px; } .mb-lg { margin-bottom: 24px; }
.hidden { display: none !important; }

/* ====== Callout ====== */
.callout {
  display: grid; grid-template-columns: 20px 1fr; gap: 12px;
  padding: 14px 16px; border-radius: var(--r-md); font
